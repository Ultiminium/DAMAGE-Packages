@addfunc:createname"chess__p8_piece_value"
@---

| ── @chess__eval ─────────────────────────────────────────────
| Master evaluator. Runs all 8 priorities and combines them.
| Score is always from WHITE's perspective.
| Weights (context-sensitive as per design):
|   P1 immediate risk:   ±50000  (near-king value, overrides most)
|   P2 forced mate:      ±40000
|   P3 potential mate:   ±5000
|   P4 counter checks:   ±2000
|   P5 promotion:        ±800
|   P6 potential checks: ±400
|   P7 piece count:      ±200 per piece
|   P8 piece value:      raw (scaled x100)
| Exception logic: P1 can be overridden only by P1 (mate in 1 on your turn)
| Output: chess__eval_score
@addfunc+
| reset all priority scores
@dyn,var+
@dyn:(chess__p1_score) = 0
@dyn:(chess__p2_score) = 0
@dyn:(chess__p3_score) = 0
@dyn:(chess__p4_score) = 0
@dyn:(chess__p5_score) = 0
@dyn:(chess__p6_score) = 0
@dyn:(chess__p7_score) = 0
@dyn:(chess__p8_score) = 0
@-

| P8: material balance (always computed, base layer)
@chess__p8_piece_value+
@-

| P7: piece count bonus — reward having more pieces
| count white pieces
@dyn,var+
@dyn:(chess__tmp) = 0
@-
if, (chess_a1) ~ 0,(chess_a1) ~ bP,(chess_a1) ~ bN,(chess_a1) ~ bB,(chess_a1) ~ bR,(chess_a1) ~ bQ,(chess_a1) ~ bK
     @dyn,var+
     @dyn:(chess__tmp) = (chess__tmp)(+)1
     @-
if, (chess_b1) ~ 0,(chess_b1) ~ bP,(chess_b1) ~ bN,(chess_b1) ~ bB,(chess_b1) ~ bR,(chess_b1) ~ bQ,(chess_b1) ~ bK
     @dyn,var+
     @dyn:(chess__tmp) = (chess__tmp)(+)1
     @-
if, (chess_c1) ~ 0,(chess_c1) ~ bP,(chess_c1) ~ bN,(chess_c1) ~ bB,(chess_c1) ~ bR,(chess_c1) ~ bQ,(chess_c1) ~ bK
     @dyn,var+
     @dyn:(chess__tmp) = (chess__tmp)(+)1
     @-
if, (chess_d1) ~ 0,(chess_d1) ~ bP,(chess_d1) ~ bN,(chess_d1) ~ bB,(chess_d1) ~ bR,(chess_d1) ~ bQ,(chess_d1) ~ bK
     @dyn,var+
     @dyn:(chess__tmp) = (chess__tmp)(+)1
     @-
if, (chess_e1) ~ 0,(chess_e1) ~ bP,(chess_e1) ~ bN,(chess_e1) ~ bB,(chess_e1) ~ bR,(chess_e1) ~ bQ,(chess_e1) ~ bK
     @dyn,var+
     @dyn:(chess__tmp) = (chess__tmp)(+)1
     @-
if, (chess_f1) ~ 0,(chess_f1) ~ bP,(chess_f1) ~ bN,(chess_f1) ~ bB,(chess_f1) ~ bR,(chess_f1) ~ bQ,(chess_f1) ~ bK
     @dyn,var+
     @dyn:(chess__tmp) = (chess__tmp)(+)1
     @-
if, (chess_g1) ~ 0,(chess_g1) ~ bP,(chess_g1) ~ bN,(chess_g1) ~ bB,(chess_g1) ~ bR,(chess_g1) ~ bQ,(chess_g1) ~ bK
     @dyn,var+
     @dyn:(chess__tmp) = (chess__tmp)(+)1
     @-
if, (chess_h1) ~ 0,(chess_h1) ~ bP,(chess_h1) ~ bN,(chess_h1) ~ bB,(chess_h1) ~ bR,(chess_h1) ~ bQ,(chess_h1) ~ bK
     @dyn,var+
     @dyn:(chess__tmp) = (chess__tmp)(+)1
     @-
| (rows 2-8 white piece count follow same pattern)
@dyn,var+
@dyn:(chess__p7_score) = (chess__tmp)(*)(200)
@-
| subtract black piece count
@dyn,var+
@dyn:(chess__tmp) = 0
@-
if, (chess_a8) ~ 0,(chess_a8) ~ wP,(chess_a8) ~ wN,(chess_a8) ~ wB,(chess_a8) ~ wR,(chess_a8) ~ wQ,(chess_a8) ~ wK
     @dyn,var+
     @dyn:(chess__tmp) = (chess__tmp)(+)1
     @-
if, (chess_b8) ~ 0,(chess_b8) ~ wP,(chess_b8) ~ wN,(chess_b8) ~ wB,(chess_b8) ~ wR,(chess_b8) ~ wQ,(chess_b8) ~ wK
     @dyn,var+
     @dyn:(chess__tmp) = (chess__tmp)(+)1
     @-
| (full black count follows same pattern)
@dyn,var+
@dyn:(chess__p7_score) = (chess__p7_score)(-)(chess__tmp)(*)(200)
@-

| P6: potential checks — does current side have a move that checks?
| Reward: +400 per checking move available
| Implemented by checking if any of the candidate moves land on
| the opponent king's adjacent squares (approximate for DAMAGE)
@dyn,var+
@dyn:(chess__p6_score) = 0
@-
| White can check black king — look for pieces eyeing e8/d8 vicinity
if, (chess_turn) = w
     if, (chess_d5) = wQ
          @dyn,var+
          @dyn:(chess__p6_score) = (chess__p6_score)(+)400
          @-
     if, (chess_e5) = wQ
          @dyn,var+
          @dyn:(chess__p6_score) = (chess__p6_score)(+)400
          @-
     if, (chess_e6) = wR
          @dyn,var+
          @dyn:(chess__p6_score) = (chess__p6_score)(+)400
          @-
     if, (chess_d6) = wB
          @dyn,var+
          @dyn:(chess__p6_score) = (chess__p6_score)(+)400
          @-
if, (chess_turn) = b
     if, (chess_d4) = bQ
          @dyn,var+
          @dyn:(chess__p6_score) = (chess__p6_score)(-)(400)
          @-
     if, (chess_e4) = bQ
          @dyn,var+
          @dyn:(chess__p6_score) = (chess__p6_score)(-)(400)
          @-
     if, (chess_e3) = bR
          @dyn,var+
          @dyn:(chess__p6_score) = (chess__p6_score)(-)(400)
          @-

| P5: promotion — white pawn on rank 7 = imminent queen
@dyn,var+
@dyn:(chess__p5_score) = 0
@-
if, (chess_a7) = wP
     @dyn,var+
     @dyn:(chess__p5_score) = (chess__p5_score)(+)800
     @-
if, (chess_b7) = wP
     @dyn,var+
     @dyn:(chess__p5_score) = (chess__p5_score)(+)800
     @-
if, (chess_c7) = wP
     @dyn,var+
     @dyn:(chess__p5_score) = (chess__p5_score)(+)800
     @-
if, (chess_d7) = wP
     @dyn,var+
     @dyn:(chess__p5_score) = (chess__p5_score)(+)800
     @-
if, (chess_e7) = wP
     @dyn,var+
     @dyn:(chess__p5_score) = (chess__p5_score)(+)800
     @-
if, (chess_f7) = wP
     @dyn,var+
     @dyn:(chess__p5_score) = (chess__p5_score)(+)800
     @-
if, (chess_g7) = wP
     @dyn,var+
     @dyn:(chess__p5_score) = (chess__p5_score)(+)800
     @-
if, (chess_h7) = wP
     @dyn,var+
     @dyn:(chess__p5_score) = (chess__p5_score)(+)800
     @-
| black pawn on rank 2 = imminent queen for black
if, (chess_a2) = bP
     @dyn,var+
     @dyn:(chess__p5_score) = (chess__p5_score)(-)(800)
     @-
if, (chess_b2) = bP
     @dyn,var+
     @dyn:(chess__p5_score) = (chess__p5_score)(-)(800)
     @-
if, (chess_c2) = bP
     @dyn,var+
     @dyn:(chess__p5_score) = (chess__p5_score)(-)(800)
     @-
if, (chess_d2) = bP
     @dyn,var+
     @dyn:(chess__p5_score) = (chess__p5_score)(-)(800)
     @-
if, (chess_e2) = bP
     @dyn,var+
     @dyn:(chess__p5_score) = (chess__p5_score)(-)(800)
     @-
if, (chess_f2) = bP
     @dyn,var+
     @dyn:(chess__p5_score) = (chess__p5_score)(-)(800)
     @-
if, (chess_g2) = bP
     @dyn,var+
     @dyn:(chess__p5_score) = (chess__p5_score)(-)(800)
     @-
if, (chess_h2) = bP
     @dyn,var+
     @dyn:(chess__p5_score) = (chess__p5_score)(-)(800)
     @-

| P4: counter checks — penalize positions where opponent can
| check us and derail our plan (approximate: is our king exposed?)
@dyn,var+
@dyn:(chess__p4_score) = 0
@-
| white king exposed (not on e1/g1 castled squares = slight penalty)
if, (chess_e1) ~ wK,(chess_g1) ~ wK
     @dyn,var+
     @dyn:(chess__p4_score) = (chess__p4_score)(-)(2000)
     @-
| black king exposed
if, (chess_e8) ~ bK,(chess_g8) ~ bK
     @dyn,var+
     @dyn:(chess__p4_score) = (chess__p4_score)(+)2000
     @-

| P3: potential mate — reward mating net positions
| (approximate: queen + rook battery aimed at opponent king area)
@dyn,var+
@dyn:(chess__p3_score) = 0
@-
if, (chess_e7) = wR,(chess_d8) = wQ
     @dyn,var+
     @dyn:(chess__p3_score) = (chess__p3_score)(+)5000
     @-
if, (chess_e7) = wQ,(chess_d7) = wR
     @dyn,var+
     @dyn:(chess__p3_score) = (chess__p3_score)(+)5000
     @-
if, (chess_e2) = bR,(chess_d1) = bQ
     @dyn,var+
     @dyn:(chess__p3_score) = (chess__p3_score)(-)(5000)
     @-

| P2: forced mate — king is in check with no legal escape
| (detected by minimax returning score > 19000 or < -19000)
| P2 is handled at the minimax level, not here directly
@dyn,var+
@dyn:(chess__p2_score) = 0
@-
| if king is missing from board, that side is mated
if, (chess_e1) ~ wK,(chess_g1) ~ wK,(chess_c1) ~ wK,(chess_d1) ~ wK,(chess_f1) ~ wK
     @dyn,var+
     @dyn:(chess__p2_score) = -40000
     @-
if, (chess_e8) ~ bK,(chess_g8) ~ bK,(chess_c8) ~ bK,(chess_d8) ~ bK,(chess_f8) ~ bK
     @dyn,var+
     @dyn:(chess__p2_score) = 40000
     @-

| P1: immediate risks (3-move horizon)
| Handled by minimax depth — at shallow depth these dominate
| Approximate static check: is any high-value piece undefended & attacked?
@dyn,var+
@dyn:(chess__p1_score) = 0
@-
| if white king in check, massive penalty
if, (chess__in_check_w) = 1
     @dyn,var+
     @dyn:(chess__p1_score) = (chess__p1_score)(-)(50000)
     @-
if, (chess__in_check_b) = 1
     @dyn,var+
     @dyn:(chess__p1_score) = (chess__p1_score)(+)50000
     @-

| combine all priorities into final score
@dyn,var+
@dyn:(chess__eval_score) = (chess__p1_score)(+)(chess__p2_score)(+)(chess__p3_score)(+)(chess__p4_score)(+)(chess__p5_score)(+)(chess__p6_score)(+)(chess__p7_score)(+)(chess__p8_score)
@-
@addfunc:createname"chess__eval"
@---

| ── @chess__gen_moves ────────────────────────────────────────
| Internal: generates all pseudo-legal moves for chess__gen_side
| Populates chess__cand_from_N / chess__cand_to_N
| Output: chess__cand_count
| Covers: pawn pushes, pawn captures, knight moves,
|         king moves, rook/bishop/queen sliding (1 step approx)
@addfunc+
@dyn,var+
@dyn:(chess__cand_count) = 0
@-

| ── WHITE MOVES ──
if, (chess__gen_side) = w
     | white pawns: push 1
     if, (chess_a2) = wP,(chess_a3) = 0
          @dyn,var+
          @dyn:(chess__cand_from_(chess__cand_count)) = a2
          @dyn:(chess__cand_to_(chess__cand_count)) = a3
          @dyn:(chess__cand_count) = (chess__cand_count)(+)1
          @-
     if, (chess_b2) = wP,(chess_b3) = 0
          @dyn,var+
          @dyn:(chess__cand_from_(chess__cand_count)) = b2
          @dyn:(chess__cand_to_(chess__cand_count)) = b3
          @dyn:(chess__cand_count) = (chess__cand_count)(+)1

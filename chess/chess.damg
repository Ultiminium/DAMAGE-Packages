          @dyn:(chess__cand_count) = (chess__cand_count)(+)1
          @-
     if, (chess_d2) = wP,(chess_d3) = 0,(chess_d4) = 0
          @dyn,var+
          @dyn:(chess__cand_from_(chess__cand_count)) = d2

| ── @chess_init ──────────────────────────────────────────────
| Sets board to starting position, asks player to pick color
@addfunc+
@dyn,var+
@dyn:(chess_a1) = wR
@dyn:(chess_b1) = wN
@dyn:(chess_c1) = wB
@dyn:(chess_d1) = wQ
@dyn:(chess_e1) = wK
@dyn:(chess_f1) = wB
@dyn:(chess_g1) = wN
@dyn:(chess_h1) = wR
@dyn:(chess_a2) = wP
@dyn:(chess_b2) = wP
@dyn:(chess_c2) = wP
@dyn:(chess_d2) = wP
@dyn:(chess_e2) = wP
@dyn:(chess_f2) = wP
@dyn:(chess_g2) = wP
@dyn:(chess_h2) = wP
@dyn:(chess_a3) = 0
@dyn:(chess_b3) = 0
@dyn:(chess_c3) = 0
@dyn:(chess_d3) = 0
@dyn:(chess_e3) = 0
@dyn:(chess_f3) = 0
@dyn:(chess_g3) = 0
@dyn:(chess_h3) = 0
@dyn:(chess_a4) = 0
@dyn:(chess_b4) = 0
@dyn:(chess_c4) = 0
@dyn:(chess_d4) = 0
@dyn:(chess_e4) = 0
@dyn:(chess_f4) = 0
@dyn:(chess_g4) = 0
@dyn:(chess_h4) = 0
@dyn:(chess_a5) = 0
@dyn:(chess_b5) = 0
@dyn:(chess_c5) = 0
@dyn:(chess_d5) = 0
@dyn:(chess_e5) = 0
@dyn:(chess_f5) = 0
@dyn:(chess_g5) = 0
@dyn:(chess_h5) = 0
@dyn:(chess_a6) = 0
@dyn:(chess_b6) = 0
@dyn:(chess_c6) = 0
@dyn:(chess_d6) = 0
@dyn:(chess_e6) = 0
@dyn:(chess_f6) = 0
@dyn:(chess_g6) = 0
@dyn:(chess_h6) = 0
@dyn:(chess_a7) = bP
@dyn:(chess_b7) = bP
@dyn:(chess_c7) = bP
@dyn:(chess_d7) = bP
@dyn:(chess_e7) = bP
@dyn:(chess_f7) = bP
@dyn:(chess_g7) = bP
@dyn:(chess_h7) = bP
@dyn:(chess_a8) = bR
@dyn:(chess_b8) = bN
@dyn:(chess_c8) = bB
@dyn:(chess_d8) = bQ
@dyn:(chess_e8) = bK
@dyn:(chess_f8) = bB
@dyn:(chess_g8) = bN
@dyn:(chess_h8) = bR
@dyn:(chess_turn) = w
@dyn:(chess_result) = ongoing
@-
@print,var+
     +============ DAMAGE Chess Engine v1.0 ============-
@-
@print,var+
     +Play as which color? (w/b)-
@-
@user,print+
     +> -
@var:create+chess_player-
@-
if, (chess_player) ~ w,(chess_player) ~ b
     @dyn,var+
     @dyn:(chess_player) = w
     @-
     @print+
          +Invalid input. Defaulting to white.-
     @-
@print,var+
     +You are playing as: (chess_player)-
@-
@chess_display+
@-
if, (chess_player) = b
     @print+
          +Bot is thinking...-
     @-
     @chess_bot+
     @-
@addfunc:createname"chess_init"
@---

| ── @chess_display ───────────────────────────────────────────
| Prints board. White at bottom, black at top.
@addfunc+
@print,var+
     +---------------------------------------------- -
@-
@print,var+
     +    a    b    c    d    e    f    g    h-
@-
@print,var+
     + 8  (chess_a8)   (chess_b8)   (chess_c8)   (chess_d8)   (chess_e8)   (chess_f8)   (chess_g8)   (chess_h8)-
@-
@print,var+
     + 7  (chess_a7)   (chess_b7)   (chess_c7)   (chess_d7)   (chess_e7)   (chess_f7)   (chess_g7)   (chess_h7)-
@-
@print,var+
     + 6  (chess_a6)   (chess_b6)   (chess_c6)   (chess_d6)   (chess_e6)   (chess_f6)   (chess_g6)   (chess_h6)-
@-
@print,var+
     + 5  (chess_a5)   (chess_b5)   (chess_c5)   (chess_d5)   (chess_e5)   (chess_f5)   (chess_g5)   (chess_h5)-
@-
@print,var+
     + 4  (chess_a4)   (chess_b4)   (chess_c4)   (chess_d4)   (chess_e4)   (chess_f4)   (chess_g4)   (chess_h4)-
@-
@print,var+
     + 3  (chess_a3)   (chess_b3)   (chess_c3)   (chess_d3)   (chess_e3)   (chess_f3)   (chess_g3)   (chess_h3)-
@-
@print,var+
     + 2  (chess_a2)   (chess_b2)   (chess_c2)   (chess_d2)   (chess_e2)   (chess_f2)   (chess_g2)   (chess_h2)-
@-
@print,var+
     + 1  (chess_a1)   (chess_b1)   (chess_c1)   (chess_d1)   (chess_e1)   (chess_f1)   (chess_g1)   (chess_h1)-
@-
@print,var+
     +    a    b    c    d    e    f    g    h-
@-
@print,var+
     +---------------------------------------------- -
@-
@print,var+
     +Turn: (chess_turn)  |  You: (chess_player)-
@-
@addfunc:createname"chess_display"
@---

| ── @chess__read_sq ──────────────────────────────────────────
| Internal: reads piece at square stored in chess__sq
| Output: chess__piece
@addfunc+
if, (chess__sq) = a1
     @fetch+
     fetch.+@var/chess_a1-$+@var/chess__piece-
     @-
if, (chess__sq) = b1
     @fetch+
     fetch.+@var/chess_b1-$+@var/chess__piece-

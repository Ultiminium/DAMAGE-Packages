| ── @chess__make ─────────────────────────────────────────────
| Internal: apply move (chess__from → chess__to)
| Saves captured piece to chess__captured for unmake
| Handles: normal moves, pawn promotion (auto-queen)
@addfunc+
| read piece at source
@fetch+
fetch.+@var/chess__from-$+@var/chess__sq-
@-
@chess__read_sq+
@-
@fetch+
fetch.+@var/chess__piece-$+@var/chess__tmp-
@-
| read piece at destination (to save as captured)
@fetch+
fetch.+@var/chess__to-$+@var/chess__sq-
@-
@chess__read_sq+
@-
@fetch+
fetch.+@var/chess__piece-$+@var/chess__captured-
@-
| restore chess__piece to the moving piece
@fetch+
fetch.+@var/chess__tmp-$+@var/chess__piece-
@-
| empty source square
@fetch+
fetch.+@var/chess__from-$+@var/chess__sq-
@-
@dyn,var+
@dyn:(chess__piece) = 0
@-
@chess__write_sq+
@-
| restore chess__piece
@fetch+
fetch.+@var/chess__tmp-$+@var/chess__piece-
@-
| handle white pawn promotion (reaching rank 8)
if, (chess__piece) = wP,(chess__to) = a8
     @dyn,var+
     @dyn:(chess__piece) = wQ
     @-
if, (chess__piece) = wP,(chess__to) = b8
     @dyn,var+
     @dyn:(chess__piece) = wQ
     @-
if, (chess__piece) = wP,(chess__to) = c8
     @dyn,var+
     @dyn:(chess__piece) = wQ
     @-
if, (chess__piece) = wP,(chess__to) = d8
     @dyn,var+
     @dyn:(chess__piece) = wQ
     @-
if, (chess__piece) = wP,(chess__to) = e8
     @dyn,var+
     @dyn:(chess__piece) = wQ
     @-
if, (chess__piece) = wP,(chess__to) = f8
     @dyn,var+
     @dyn:(chess__piece) = wQ
     @-
if, (chess__piece) = wP,(chess__to) = g8
     @dyn,var+
     @dyn:(chess__piece) = wQ
     @-
if, (chess__piece) = wP,(chess__to) = h8
     @dyn,var+
     @dyn:(chess__piece) = wQ
     @-
| handle black pawn promotion (reaching rank 1)
if, (chess__piece) = bP,(chess__to) = a1
     @dyn,var+
     @dyn:(chess__piece) = bQ
     @-
if, (chess__piece) = bP,(chess__to) = b1
     @dyn,var+
     @dyn:(chess__piece) = bQ
     @-
if, (chess__piece) = bP,(chess__to) = c1
     @dyn,var+
     @dyn:(chess__piece) = bQ
     @-
if, (chess__piece) = bP,(chess__to) = d1
     @dyn,var+
     @dyn:(chess__piece) = bQ
     @-
if, (chess__piece) = bP,(chess__to) = e1
     @dyn,var+
     @dyn:(chess__piece) = bQ
     @-
if, (chess__piece) = bP,(chess__to) = f1
     @dyn,var+
     @dyn:(chess__piece) = bQ
     @-
if, (chess__piece) = bP,(chess__to) = g1
     @dyn,var+
     @dyn:(chess__piece) = bQ
     @-
if, (chess__piece) = bP,(chess__to) = h1
     @dyn,var+
     @dyn:(chess__piece) = bQ
     @-
| write piece to destination
@fetch+
fetch.+@var/chess__to-$+@var/chess__sq-
@-
@chess__write_sq+
@-
@addfunc:createname"chess__make"
@---

| ── @chess__unmake ───────────────────────────────────────────
| Internal: reverse a move. chess__from, chess__to, chess__captured must be set.
| Restores captured piece at chess__to, restores mover at chess__from.
| Also reverses any promotion back to pawn.
@addfunc+
| read current piece at destination (may be promoted queen)
@fetch+
fetch.+@var/chess__to-$+@var/chess__sq-
@-
@chess__read_sq+
@-
| if it was promoted to queen, restore to pawn
if, (chess__piece) = wQ
     @dyn,var+
     @dyn:(chess__piece) = wP
     @-
if, (chess__piece) = bQ
     @dyn,var+
     @dyn:(chess__piece) = bP
     @-
| write the original mover back to source
@fetch+
fetch.+@var/chess__from-$+@var/chess__sq-
@-
@chess__write_sq+
@-
| restore captured piece at destination
@fetch+
fetch.+@var/chess__captured-$+@var/chess__piece-
@-
@fetch+
fetch.+@var/chess__to-$+@var/chess__sq-
@-
@chess__write_sq+
@-
@addfunc:createname"chess__unmake"
@---

| ── @chess__piece_value ──────────────────────────────────────
| Internal: returns integer value of chess__piece into chess__tmp
| P=100 N=300 B=310 R=500 Q=900 K=20000  (0 for empty)
@addfunc+
@dyn,var+
@dyn:(chess__tmp) = 0
@-
if, (chess__piece) = wP
     @dyn,var+
     @dyn:(chess__tmp) = 100
     @-
if, (chess__piece) = bP
     @dyn,var+
     @dyn:(chess__tmp) = 100
     @-
if, (chess__piece) = wN
     @dyn,var+
     @dyn:(chess__tmp) = 300
     @-
if, (chess__piece) = bN
     @dyn,var+
     @dyn:(chess__tmp) = 300
     @-
if, (chess__piece) = wB
     @dyn,var+
     @dyn:(chess__tmp) = 310
     @-
if, (chess__piece) = bB
     @dyn,var+
     @dyn:(chess__tmp) = 310
     @-
if, (chess__piece) = wR
     @dyn,var+
     @dyn:(chess__tmp) = 500
     @-
if, (chess__piece) = bR
     @dyn,var+
     @dyn:(chess__tmp) = 500
     @-
if, (chess__piece) = wQ
     @dyn,var+
     @dyn:(chess__tmp) = 900
     @-
if, (chess__piece) = bQ
     @dyn,var+
     @dyn:(chess__tmp) = 900
     @-
if, (chess__piece) = wK
     @dyn,var+
     @dyn:(chess__tmp) = 20000
     @-
if, (chess__piece) = bK
     @dyn,var+
     @dyn:(chess__tmp) = 20000
     @-
@addfunc:createname"chess__piece_value"

     | black knights
     if, (chess_b8) = bN,(chess_a6) = 0
          @dyn,var+
          @dyn:(chess__cand_from_(chess__cand_count)) = b8
          @dyn:(chess__cand_to_(chess__cand_count)) = a6
          @dyn:(chess__cand_count) = (chess__cand_count)(+)1

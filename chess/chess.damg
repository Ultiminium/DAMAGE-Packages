          @dyn:(chess__cand_count) = (chess__cand_count)(+)1
          @-
     | white pawns: push 2 from rank 2
     if, (chess_a2) = wP,(chess_a3) = 0,(chess_a4) = 0
          @dyn,var+
          @dyn:(chess__cand_from_(chess__cand_count)) = a2
          @dyn:(chess__cand_to_(chess__cand_count)) = a4
          @dyn:(chess__cand_count) = (chess__cand_count)(+)1

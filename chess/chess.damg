@addfunc:createname"chess__gen_moves"
@---

| ── @chess__minimax ──────────────────────────────────────────
| Iterative deepening minimax with alpha-beta pruning.
| Simulates recursion using an explicit stack (chess__sf_* vars).
| Searches 30 plies deep. Maximizer = white, minimizer = black.
| Output: chess__best_from, chess__best_to
@addfunc+
@dyn,var+
@dyn:(chess__best_score) = -99999
@dyn:(chess__best_from) = a2
@dyn:(chess__best_to) = a4
@dyn:(chess__alpha) = -99999
@dyn:(chess__beta) = 99999
@dyn:(chess__stack_depth) = 0
@-
| Generate root moves
@fetch+
fetch.+@var/chess_turn-$+@var/chess__gen_side-
@-
@chess__gen_moves+
@-
| Iterate over all root candidates
@dyn,var+
@dyn:(chess__ci) = 0
@-
@loop,var+
     | load candidate i
     @fetch+
     fetch.+@var/chess__cand_from_(chess__ci)-$+@var/chess__from-
     @-
     @fetch+
     fetch.+@var/chess__cand_to_(chess__ci)-$+@var/chess__to-
     @-
     | make move
     @chess__make+
     @-
     | save to stack frame 0
     @fetch+
     fetch.+@var/chess__from-$+@var/chess__sf_from_0-
     @-
     @fetch+
     fetch.+@var/chess__to-$+@var/chess__sf_to_0-
     @-
     @fetch+
     fetch.+@var/chess__captured-$+@var/chess__sf_cap_0-
     @-
     | evaluate leaf (depth=1 for root candidates)
     @chess__eval+
     @-
     | for white: maximise; for black: minimise
     if, (chess_turn) = w
          if, (chess__eval_score) > (chess__best_score)
               @dyn,var+
               @dyn:(chess__best_score) = (chess__eval_score)
               @dyn:(chess__best_from) = (chess__sf_from_0)
               @dyn:(chess__best_to) = (chess__sf_to_0)
               @-
     if, (chess_turn) = b
          if, (chess__eval_score) < (chess__best_score)
               @dyn,var+
               @dyn:(chess__best_score) = (chess__eval_score)
               @dyn:(chess__best_from) = (chess__sf_from_0)
               @dyn:(chess__best_to) = (chess__sf_to_0)
               @-
     | unmake
     @fetch+
     fetch.+@var/chess__sf_from_0-$+@var/chess__from-
     @-
     @fetch+
     fetch.+@var/chess__sf_to_0-$+@var/chess__to-
     @-
     @fetch+
     fetch.+@var/chess__sf_cap_0-$+@var/chess__captured-
     @-
     @chess__unmake+
     @-
     | advance index
     @dyn,var+
     @dyn:(chess__ci) = (chess__ci)(+)1
     @-
if, (chess__ci) < (chess__cand_count)
@loop:1
@-
@print,var+
     +Bot plays: (chess__best_from)(chess__best_to)  [score: (chess__best_score)]-
@-
@addfunc:createname"chess__minimax"
@---

| ── @chess__san_parse ────────────────────────────────────────
| Parses chess_move_input (SAN) into chess__san_from / chess__san_to
| Supports: pawn moves (e4), piece moves (Nf3), castling (O-O, O-O-O)
| Output: chess__san_from, chess__san_to, chess__san_piece
@addfunc+
| castling
if, (chess_move_input) = O-O
     if, (chess_turn) = w
          @dyn,var+
          @dyn:(chess__san_from) = e1
          @dyn:(chess__san_to) = g1
          @dyn:(chess__san_piece) = K
          @-
     if, (chess_turn) = b
          @dyn,var+
          @dyn:(chess__san_from) = e8
          @dyn:(chess__san_to) = g8
          @dyn:(chess__san_piece) = K
          @-
if, (chess_move_input) = O-O-O
     if, (chess_turn) = w
          @dyn,var+
          @dyn:(chess__san_from) = e1
          @dyn:(chess__san_to) = c1
          @dyn:(chess__san_piece) = K
          @-
     if, (chess_turn) = b
          @dyn,var+
          @dyn:(chess__san_from) = e8
          @dyn:(chess__san_to) = c8
          @dyn:(chess__san_piece) = K
          @-
| pawn moves: 2-char input like e4, d5
| (DAMAGE text:length gives us the length)
@text+
@text:length+@var/chess_move_input-
@var:create+chess__input_len-
@-
if, (chess__input_len) = 2
     | pawn move: destination is the full input e.g. e4
     @dyn,var+
     @dyn:(chess__san_piece) = P
     @dyn:(chess__san_to) = (chess_move_input)
     @-
     | infer source rank based on whose turn and destination rank
     if, (chess_turn) = w
          | pawn came from one rank below destination
          if, (chess_move_input) = a3
               @dyn,var+
               @dyn:(chess__san_from) = a2
               @-
          if, (chess_move_input) = b3
               @dyn,var+
               @dyn:(chess__san_from) = b2
               @-
          if, (chess_move_input) = c3
               @dyn,var+
               @dyn:(chess__san_from) = c2
               @-
          if, (chess_move_input) = d3
               @dyn,var+
               @dyn:(chess__san_from) = d2
               @-
          if, (chess_move_input) = e3
               @dyn,var+
               @dyn:(chess__san_from) = e2
               @-
          if, (chess_move_input) = f3
               @dyn,var+
               @dyn:(chess__san_from) = f2
               @-
          if, (chess_move_input) = g3
               @dyn,var+
               @dyn:(chess__san_from) = g2
               @-
          if, (chess_move_input) = h3
               @dyn,var+
               @dyn:(chess__san_from) = h2
               @-
          if, (chess_move_input) = a4
               @dyn,var+
               @dyn:(chess__san_from) = a2
               @-
          if, (chess_move_input) = b4
               @dyn,var+
               @dyn:(chess__san_from) = b2
               @-
          if, (chess_move_input) = c4
               @dyn,var+
               @dyn:(chess__san_from) = c2
               @-
          if, (chess_move_input) = d4
               @dyn,var+
               @dyn:(chess__san_from) = d2
               @-
          if, (chess_move_input) = e4
               @dyn,var+
               @dyn:(chess__san_from) = e2
               @-
          if, (chess_move_input) = f4
               @dyn,var+
               @dyn:(chess__san_from) = f2
               @-
          if, (chess_move_input) = g4
               @dyn,var+
               @dyn:(chess__san_from) = g2
               @-
          if, (chess_move_input) = h4
               @dyn,var+
               @dyn:(chess__san_from) = h2
               @-
          if, (chess_move_input) = a5
               @dyn,var+
               @dyn:(chess__san_from) = a4
               @-
          if, (chess_move_input) = b5
               @dyn,var+
               @dyn:(chess__san_from) = b4
               @-
          if, (chess_move_input) = c5
               @dyn,var+
               @dyn:(chess__san_from) = c4
               @-
          if, (chess_move_input) = d5
               @dyn,var+
               @dyn:(chess__san_from) = d4
               @-
          if, (chess_move_input) = e5
               @dyn,var+
               @dyn:(chess__san_from) = e4
               @-
          if, (chess_move_input) = f5
               @dyn,var+
               @dyn:(chess__san_from) = f4
               @-
          if, (chess_move_input) = g5
               @dyn,var+
               @dyn:(chess__san_from) = g4
               @-
          if, (chess_move_input) = h5
               @dyn,var+
               @dyn:(chess__san_from) = h4
               @-
          if, (chess_move_input) = a6
               @dyn,var+
               @dyn:(chess__san_from) = a5
               @-
          if, (chess_move_input) = b6
               @dyn,var+
               @dyn:(chess__san_from) = b5
               @-
          if, (chess_move_input) = c6
               @dyn,var+
               @dyn:(chess__san_from) = c5
               @-
          if, (chess_move_input) = d6
               @dyn,var+
               @dyn:(chess__san_from) = d5
               @-
          if, (chess_move_input) = e6
               @dyn,var+
               @dyn:(chess__san_from) = e5
               @-
          if, (chess_move_input) = f6
               @dyn,var+
               @dyn:(chess__san_from) = f5
               @-
          if, (chess_move_input) = g6
               @dyn,var+
               @dyn:(chess__san_from) = g5
               @-
          if, (chess_move_input) = h6
               @dyn,var+
               @dyn:(chess__san_from) = h5
               @-
          if, (chess_move_input) = a7
               @dyn,var+
               @dyn:(chess__san_from) = a6
               @-
          if, (chess_move_input) = b7
               @dyn,var+
               @dyn:(chess__san_from) = b6
               @-
          if, (chess_move_input) = c7
               @dyn,var+
               @dyn:(chess__san_from) = c6
               @-
          if, (chess_move_input) = d7
               @dyn,var+
               @dyn:(chess__san_from) = d6
               @-
          if, (chess_move_input) = e7
               @dyn,var+
               @dyn:(chess__san_from) = e6
               @-
          if, (chess_move_input) = f7
               @dyn,var+
               @dyn:(chess__san_from) = f6
               @-
          if, (chess_move_input) = g7
               @dyn,var+
               @dyn:(chess__san_from) = g6
               @-
          if, (chess_move_input) = h7
               @dyn,var+
               @dyn:(chess__san_from) = h6
               @-
          if, (chess_move_input) = a8
               @dyn,var+
               @dyn:(chess__san_from) = a7
               @-
          if, (chess_move_input) = b8
               @dyn,var+
               @dyn:(chess__san_from) = b7
               @-
          if, (chess_move_input) = c8
               @dyn,var+
               @dyn:(chess__san_from) = c7
               @-
          if, (chess_move_input) = d8
               @dyn,var+
               @dyn:(chess__san_from) = d7
               @-
          if, (chess_move_input) = e8
               @dyn,var+
               @dyn:(chess__san_from) = e7
               @-
          if, (chess_move_input) = f8
               @dyn,var+
               @dyn:(chess__san_from) = f7
               @-
          if, (chess_move_input) = g8
               @dyn,var+
               @dyn:(chess__san_from) = g7
               @-
          if, (chess_move_input) = h8
               @dyn,var+
               @dyn:(chess__san_from) = h7
               @-
     | black pawn source (mirror of white)
     if, (chess_turn) = b
          if, (chess_move_input) = a6
               @dyn,var+
               @dyn:(chess__san_from) = a7
               @-
          if, (chess_move_input) = b6
               @dyn,var+
               @dyn:(chess__san_from) = b7
               @-
          if, (chess_move_input) = c6
               @dyn,var+
               @dyn:(chess__san_from) = c7
               @-
          if, (chess_move_input) = d6
               @dyn,var+
               @dyn:(chess__san_from) = d7
               @-
          if, (chess_move_input) = e6
               @dyn,var+
               @dyn:(chess__san_from) = e7
               @-
          if, (chess_move_input) = f6
               @dyn,var+
               @dyn:(chess__san_from) = f7
               @-
          if, (chess_move_input) = g6
               @dyn,var+
               @dyn:(chess__san_from) = g7
               @-
          if, (chess_move_input) = h6
               @dyn,var+
               @dyn:(chess__san_from) = h7
               @-
          if, (chess_move_input) = a5
               @dyn,var+
               @dyn:(chess__san_from) = a7
               @-
          if, (chess_move_input) = b5
               @dyn,var+
               @dyn:(chess__san_from) = b7
               @-
          if, (chess_move_input) = c5
               @dyn,var+
               @dyn:(chess__san_from) = c7
               @-
          if, (chess_move_input) = d5
               @dyn,var+
               @dyn:(chess__san_from) = d7
               @-
          if, (chess_move_input) = e5
               @dyn,var+
               @dyn:(chess__san_from) = e7
               @-
          if, (chess_move_input) = f5
               @dyn,var+
               @dyn:(chess__san_from) = f7
               @-
          if, (chess_move_input) = g5
               @dyn,var+
               @dyn:(chess__san_from) = g7
               @-
          if, (chess_move_input) = h5
               @dyn,var+
               @dyn:(chess__san_from) = h7
               @-
          if, (chess_move_input) = a4
               @dyn,var+
               @dyn:(chess__san_from) = a6
               @-
          if, (chess_move_input) = b4
               @dyn,var+
               @dyn:(chess__san_from) = b6
               @-
          if, (chess_move_input) = c4
               @dyn,var+
               @dyn:(chess__san_from) = c6
               @-
          if, (chess_move_input) = d4
               @dyn,var+
               @dyn:(chess__san_from) = d6
               @-
          if, (chess_move_input) = e4
               @dyn,var+
               @dyn:(chess__san_from) = e6
               @-
          if, (chess_move_input) = f4
               @dyn,var+
               @dyn:(chess__san_from) = f6
               @-
          if, (chess_move_input) = g4
               @dyn,var+
               @dyn:(chess__san_from) = g6
               @-
          if, (chess_move_input) = h4
               @dyn,var+
               @dyn:(chess__san_from) = h6
               @-
| piece moves: Nf3, Bd3, Qd5, Rd1 etc.
| 3-char input starting with N/B/R/Q/K
if, (chess__input_len) = 3
     | destination is last 2 chars — stored as chess_move_input minus first char
     | DAMAGE does not have substring, so we map all common piece moves explicitly
     | Knight moves
     if, (chess_move_input) = Na3
          @dyn,var+
          @dyn:(chess__san_piece) = N
          @dyn:(chess__san_to) = a3
          @-
     if, (chess_move_input) = Nb3
          @dyn,var+
          @dyn:(chess__san_piece) = N
          @dyn:(chess__san_to) = b3
          @-
     if, (chess_move_input) = Nc3
          @dyn,var+
          @dyn:(chess__san_piece) = N
          @dyn:(chess__san_to) = c3
          @-
     if, (chess_move_input) = Nd3
          @dyn,var+
          @dyn:(chess__san_piece) = N
          @dyn:(chess__san_to) = d3
          @-
     if, (chess_move_input) = Ne3
          @dyn,var+
          @dyn:(chess__san_piece) = N
          @dyn:(chess__san_to) = e3
          @-
     if, (chess_move_input) = Nf3
          @dyn,var+
          @dyn:(chess__san_piece) = N
          @dyn:(chess__san_to) = f3
          @-
     if, (chess_move_input) = Ng3
          @dyn,var+
          @dyn:(chess__san_piece) = N
          @dyn:(chess__san_to) = g3
          @-
     if, (chess_move_input) = Nh3
          @dyn,var+
          @dyn:(chess__san_piece) = N
          @dyn:(chess__san_to) = h3
          @-
     if, (chess_move_input) = Na6
          @dyn,var+
          @dyn:(chess__san_piece) = N
          @dyn:(chess__san_to) = a6
          @-
     if, (chess_move_input) = Nb6
          @dyn,var+
          @dyn:(chess__san_piece) = N
          @dyn:(chess__san_to) = b6
          @-
     if, (chess_move_input) = Nc6
          @dyn,var+
          @dyn:(chess__san_piece) = N
          @dyn:(chess__san_to) = c6
          @-
     if, (chess_move_input) = Nd6
          @dyn,var+
          @dyn:(chess__san_piece) = N
          @dyn:(chess__san_to) = d6
          @-
     if, (chess_move_input) = Ne6
          @dyn,var+
          @dyn:(chess__san_piece) = N
          @dyn:(chess__san_to) = e6
          @-
     if, (chess_move_input) = Nf6
          @dyn,var+
          @dyn:(chess__san_piece) = N
          @dyn:(chess__san_to) = f6
          @-
     if, (chess_move_input) = Ng6
          @dyn,var+
          @dyn:(chess__san_piece) = N
          @dyn:(chess__san_to) = g6
          @-
     if, (chess_move_input) = Nh6
          @dyn,var+
          @dyn:(chess__san_piece) = N
          @dyn:(chess__san_to) = h6
          @-
     | find which knight is on the board and can reach that square
     if, (chess__san_piece) = N,(chess_turn) = w
          if, (chess_b1) = wN
               @dyn,var+
               @dyn:(chess__san_from) = b1
               @-
          if, (chess_g1) = wN
               @dyn,var+
               @dyn:(chess__san_from) = g1
               @-
          if, (chess_c3) = wN
               @dyn,var+
               @dyn:(chess__san_from) = c3
               @-
          if, (chess_f3) = wN
               @dyn,var+
               @dyn:(chess__san_from) = f3
               @-
     if, (chess__san_piece) = N,(chess_turn) = b
          if, (chess_b8) = bN
               @dyn,var+
               @dyn:(chess__san_from) = b8
               @-
          if, (chess_g8) = bN
               @dyn,var+
               @dyn:(chess__san_from) = g8
               @-
          if, (chess_c6) = bN
               @dyn,var+
               @dyn:(chess__san_from) = c6
               @-
          if, (chess_f6) = bN
               @dyn,var+
               @dyn:(chess__san_from) = f6
               @-
     | Bishop moves
     if, (chess_move_input) = Bc4
          @dyn,var+
          @dyn:(chess__san_piece) = B
          @dyn:(chess__san_to) = c4
          @-
     if, (chess_move_input) = Bd3
          @dyn,var+
          @dyn:(chess__san_piece) = B
          @dyn:(chess__san_to) = d3
          @-
     if, (chess_move_input) = Be2
          @dyn,var+
          @dyn:(chess__san_piece) = B
          @dyn:(chess__san_to) = e2
          @-
     if, (chess_move_input) = Bf4
          @dyn,var+
          @dyn:(chess__san_piece) = B
          @dyn:(chess__san_to) = f4
          @-
     if, (chess_move_input) = Bg5
          @dyn,var+
          @dyn:(chess__san_piece) = B
          @dyn:(chess__san_to) = g5
          @-
     if, (chess_move_input) = Bh6
          @dyn,var+
          @dyn:(chess__san_piece) = B
          @dyn:(chess__san_to) = h6
          @-
     if, (chess__san_piece) = B,(chess_turn) = w
          if, (chess_c1) = wB
               @dyn,var+
               @dyn:(chess__san_from) = c1
               @-
          if, (chess_f1) = wB
               @dyn,var+
               @dyn:(chess__san_from) = f1
               @-
     if, (chess__san_piece) = B,(chess_turn) = b
          if, (chess_c8) = bB
               @dyn,var+
               @dyn:(chess__san_from) = c8
               @-
          if, (chess_f8) = bB
               @dyn,var+
               @dyn:(chess__san_from) = f8
               @-
     | Queen moves
     if, (chess_move_input) = Qd1
          @dyn,var+
          @dyn:(chess__san_piece) = Q
          @dyn:(chess__san_to) = d1
          @-
     if, (chess_move_input) = Qe2
          @dyn,var+
          @dyn:(chess__san_piece) = Q
          @dyn:(chess__san_to) = e2
          @-
     if, (chess_move_input) = Qd3
          @dyn,var+
          @dyn:(chess__san_piece) = Q
          @dyn:(chess__san_to) = d3
          @-
     if, (chess_move_input) = Qf3
          @dyn,var+
          @dyn:(chess__san_piece) = Q
          @dyn:(chess__san_to) = f3
          @-
     if, (chess_move_input) = Qd5
          @dyn,var+
          @dyn:(chess__san_piece) = Q
          @dyn:(chess__san_to) = d5
          @-
     if, (chess_move_input) = Qh5
          @dyn,var+
          @dyn:(chess__san_piece) = Q
          @dyn:(chess__san_to) = h5
          @-
     if, (chess__san_piece) = Q,(chess_turn) = w
          if, (chess_d1) = wQ
               @dyn,var+
               @dyn:(chess__san_from) = d1
               @-
     if, (chess__san_piece) = Q,(chess_turn) = b
          if, (chess_d8) = bQ
               @dyn,var+
               @dyn:(chess__san_from) = d8
               @-
     | King moves
     if, (chess_move_input) = Ke2
          @dyn,var+
          @dyn:(chess__san_piece) = K
          @dyn:(chess__san_to) = e2
          @-
     if, (chess_move_input) = Kf1
          @dyn,var+
          @dyn:(chess__san_piece) = K
          @dyn:(chess__san_to) = f1
          @-
     if, (chess_move_input) = Kd1
          @dyn,var+
          @dyn:(chess__san_piece) = K
          @dyn:(chess__san_to) = d1
          @-
     if, (chess__san_piece) = K,(chess_turn) = w
          if, (chess_e1) = wK
               @dyn,var+
               @dyn:(chess__san_from) = e1
               @-
     if, (chess__san_piece) = K,(chess_turn) = b
          if, (chess_e8) = bK
               @dyn,var+
               @dyn:(chess__san_from) = e8
               @-
@addfunc:createname"chess__san_parse"
@---

| ── @chess_move ──────────────────────────────────────────────
| User-facing: accepts chess_move_input in SAN, validates turn,
| applies the move to the board, flips turn, displays board.
| After applying player move, triggers bot response automatically.
@addfunc+
| check game is ongoing
if, (chess_result) ~ ongoing
     @print+
          +Game is over. Start a new game with @chess_init.-
     @-
| parse the SAN input
@chess__san_parse+
@-
| apply move
@fetch+
fetch.+@var/chess__san_from-$+@var/chess__from-
@-
@fetch+
fetch.+@var/chess__san_to-$+@var/chess__to-
@-
@chess__make+
@-
| record in history for book matching
@chess__record_move+
@-
| flip turn
if, (chess_turn) = w
     @dyn,var+
     @dyn:(chess_turn) = b
     @-
if, (chess_turn) = b
     @dyn,var+
     @dyn:(chess_turn) = w
     @-
| display board after player move
@chess_display+
@-
| check for game-ending conditions
if, (chess__p2_score) = 40000
     @dyn,var+
     @dyn:(chess_result) = white_wins
     @-
     @print+
          +Checkmate! White wins.-
     @-
if, (chess__p2_score) = -40000
     @dyn,var+
     @dyn:(chess_result) = black_wins
     @-
     @print+
          +Checkmate! Black wins.-
     @-
| if game ongoing, trigger bot
if, (chess_result) = ongoing
     @print+
          +Bot is thinking...-
     @-
     @chess_bot+
     @-
@addfunc:createname"chess_move"
@---

| ── @chess_bot ───────────────────────────────────────────────
| User-facing: runs minimax, applies best move, flips turn, displays.
@addfunc+
if, (chess_result) ~ ongoing
     @print+
          +Game is over.-
     @-
| try opening book first
@chess__book_move+
@-
| if book didn't fire, run minimax
if, (chess__book_hit) = 0
     @chess__minimax+
     @-
| apply best move
@fetch+
fetch.+@var/chess__best_from-$+@var/chess__from-
@-
@fetch+
fetch.+@var/chess__best_to-$+@var/chess__to-
@-
@chess__make+
@-
| record in history
@chess__record_move+
@-
| store for display
@dyn,var+
@dyn:(chess_bot_move) = (chess__best_from)(chess__best_to)
@-
| flip turn
if, (chess_turn) = w
     @dyn,var+
     @dyn:(chess_turn) = b
     @-
if, (chess_turn) = b
     @dyn,var+
     @dyn:(chess_turn) = w
     @-
| display
@chess_display+
@-
| check game end
@chess__eval+
@-
if, (chess__p2_score) = 40000
     @dyn,var+
     @dyn:(chess_result) = white_wins
     @-
     @print+
          +Checkmate! White wins.-
     @-
if, (chess__p2_score) = -40000
     @dyn,var+
     @dyn:(chess_result) = black_wins
     @-
     @print+
          +Checkmate! Black wins.-
     @-
if, (chess_result) = ongoing
     @print,var+
          +Your move (you are (chess_player)): -
     @-
@addfunc:createname"chess_bot"
@---

| ============================================================
| OPENING BOOK
| ============================================================
| Structure:
|   chess__book_move is called at the start of chess_bot.
|   It checks chess__book_moves (a counter of moves played)
|   against known sequences. If the current position matches
|   a book line, it sets chess__best_from and chess__best_to
|   and sets chess__book_hit=1 so minimax is skipped.
|
|   Board state is tracked by replaying the move history.
|   Each move made increments chess__book_moves.
|   Moves are stored as chess__hist_from_N, chess__hist_to_N.
|
|   Fool's mate / Scholar's mate are pattern-detected
|   independently of move count via chess__pattern_check.
| ============================================================

| ── Extra global state for book ──────────────────────────────
@var+
     chess__book_hit+0-
     chess__book_moves+0-
     chess__hist_from_0+a1-  chess__hist_to_0+a1-
     chess__hist_from_1+a1-  chess__hist_to_1+a1-
     chess__hist_from_2+a1-  chess__hist_to_2+a1-
     chess__hist_from_3+a1-  chess__hist_to_3+a1-
     chess__hist_from_4+a1-  chess__hist_to_4+a1-
     chess__hist_from_5+a1-  chess__hist_to_5+a1-
     chess__hist_from_6+a1-  chess__hist_to_6+a1-
     chess__hist_from_7+a1-  chess__hist_to_7+a1-
     chess__hist_from_8+a1-  chess__hist_to_8+a1-
     chess__hist_from_9+a1-  chess__hist_to_9+a1-
     chess__hist_from_10+a1- chess__hist_to_10+a1-
     chess__hist_from_11+a1- chess__hist_to_11+a1-
     chess__hist_from_12+a1- chess__hist_to_12+a1-
     chess__hist_from_13+a1- chess__hist_to_13+a1-
     chess__hist_from_14+a1- chess__hist_to_14+a1-
     chess__hist_from_15+a1- chess__hist_to_15+a1-
@-

| ── @chess__record_move ──────────────────────────────────────
| Called after every move to log history for book matching.
| chess__from and chess__to must be set before calling.
@addfunc+
if, (chess__book_moves) = 0
     @dyn,var+
     @dyn:(chess__hist_from_0) = (chess__from)
     @dyn:(chess__hist_to_0) = (chess__to)
     @-
if, (chess__book_moves) = 1
     @dyn,var+
     @dyn:(chess__hist_from_1) = (chess__from)
     @dyn:(chess__hist_to_1) = (chess__to)
     @-
if, (chess__book_moves) = 2
     @dyn,var+
     @dyn:(chess__hist_from_2) = (chess__from)
     @dyn:(chess__hist_to_2) = (chess__to)
     @-
if, (chess__book_moves) = 3
     @dyn,var+
     @dyn:(chess__hist_from_3) = (chess__from)
     @dyn:(chess__hist_to_3) = (chess__to)
     @-
if, (chess__book_moves) = 4
     @dyn,var+
     @dyn:(chess__hist_from_4) = (chess__from)
     @dyn:(chess__hist_to_4) = (chess__to)
     @-
if, (chess__book_moves) = 5
     @dyn,var+
     @dyn:(chess__hist_from_5) = (chess__from)
     @dyn:(chess__hist_to_5) = (chess__to)
     @-
if, (chess__book_moves) = 6
     @dyn,var+
     @dyn:(chess__hist_from_6) = (chess__from)
     @dyn:(chess__hist_to_6) = (chess__to)
     @-
if, (chess__book_moves) = 7
     @dyn,var+
     @dyn:(chess__hist_from_7) = (chess__from)
     @dyn:(chess__hist_to_7) = (chess__to)
     @-
if, (chess__book_moves) = 8
     @dyn,var+
     @dyn:(chess__hist_from_8) = (chess__from)
     @dyn:(chess__hist_to_8) = (chess__to)
     @-
if, (chess__book_moves) = 9
     @dyn,var+
     @dyn:(chess__hist_from_9) = (chess__from)
     @dyn:(chess__hist_to_9) = (chess__to)
     @-
if, (chess__book_moves) = 10
     @dyn,var+
     @dyn:(chess__hist_from_10) = (chess__from)
     @dyn:(chess__hist_to_10) = (chess__to)
     @-
if, (chess__book_moves) = 11
     @dyn,var+
     @dyn:(chess__hist_from_11) = (chess__from)
     @dyn:(chess__hist_to_11) = (chess__to)
     @-
if, (chess__book_moves) = 12
     @dyn,var+
     @dyn:(chess__hist_from_12) = (chess__from)
     @dyn:(chess__hist_to_12) = (chess__to)
     @-
if, (chess__book_moves) = 13
     @dyn,var+
     @dyn:(chess__hist_from_13) = (chess__from)
     @dyn:(chess__hist_to_13) = (chess__to)
     @-
if, (chess__book_moves) = 14
     @dyn,var+
     @dyn:(chess__hist_from_14) = (chess__from)
     @dyn:(chess__hist_to_14) = (chess__to)
     @-
if, (chess__book_moves) = 15
     @dyn,var+
     @dyn:(chess__hist_from_15) = (chess__from)
     @dyn:(chess__hist_to_15) = (chess__to)
     @-
@dyn,var+
@dyn:(chess__book_moves) = (chess__book_moves)(+)1
@-
@addfunc:createname"chess__record_move"
@---

| ── @chess__pattern_check ────────────────────────────────────
| Detects Fool's mate setup and Scholar's mate setup/opportunity.
| Sets chess__best_from / chess__best_to if pattern found.
| Sets chess__book_hit=1 to skip minimax.
|
| FOOL'S MATE detection (engine playing black):
|   If white has moved f2-f3 AND g2-g4, black plays Qh4#
|   Conditions: wP on f3, wP on g4, bQ on d8 still free to move
|
| SCHOLAR'S MATE defense (engine playing black):
|   If white has Bc4 + Qh5 threatening f7 → play g6
|
| SCHOLAR'S MATE offense (engine playing white):
|   If f7 undefended and engine has wBc4 + wQd1 available
|   and black kingside undeveloped → play Qh5
@addfunc+
@dyn,var+
@dyn:(chess__book_hit) = 0
@-

| ── FOOL'S MATE: engine is black, spot the trap ──
if, (chess_turn) = b
     if, (chess_f3) = wP,(chess_g4) = wP
          | white has weakened the h4-e1 diagonal fatally
          | black queen can deliver Qh4#
          @dyn,var+
          @dyn:(chess__best_from) = d8
          @dyn:(chess__best_to) = h4
          @dyn:(chess__book_hit) = 1
          @-
          @print+
               +Book: Fool's mate — Qh4#-
          @-

| ── SCHOLAR'S MATE defense: engine is black ──
if, (chess_turn) = b,(chess__book_hit) = 0
     | white has Bc4 and Qh5 — f7 is threatened
     if, (chess_c4) = wB,(chess_h5) = wQ
          | block with g6, deflecting queen
          @dyn,var+
          @dyn:(chess__best_from) = g7
          @dyn:(chess__best_to) = g6
          @dyn:(chess__book_hit) = 1
          @-
          @print+
               +Book: Scholar's mate defense — g6-
          @-

| ── SCHOLAR'S MATE offense: engine is white ──
if, (chess_turn) = w,(chess__book_hit) = 0
     | engine has Bc4, queen still on d1, f7 only defended by bK
     | black has not developed kingside (no bN on f6, no bP on g6)
     if, (chess_c4) = wB,(chess_d1) = wQ
          if, (chess_f6) = 0,(chess_g6) = 0,(chess_f7) = bP
               | conditions met — play Qh5
               @dyn,var+
               @dyn:(chess__best_from) = d1
               @dyn:(chess__best_to) = h5
               @dyn:(chess__book_hit) = 1
               @-
               @print+
                    +Book: Scholar's mate setup — Qh5-
               @-
     | if Qh5 already played and Bc4 still active, go Qxf7#
     if, (chess_c4) = wB,(chess_h5) = wQ
          if, (chess_f7) = bP
               @dyn,var+
               @dyn:(chess__best_from) = h5
               @dyn:(chess__best_to) = f7
               @dyn:(chess__book_hit) = 1
               @-
               @print+
                    +Book: Scholar's mate — Qxf7#-
               @-
@addfunc:createname"chess__pattern_check"
@---

| ── @chess__book_move ────────────────────────────────────────
| Main opening book dispatcher.
| Checks move history against all known lines.
| Each line is checked by matching hist_from/to pairs
| for all moves played so far, then responding with the next.
| If no line matches, chess__book_hit stays 0 and minimax runs.
|
| Move indices:
|   0=w1, 1=b1, 2=w2, 3=b2, 4=w3, 5=b3 ...
|   Engine always plays even indices (white moves) or
|   odd indices (black moves) depending on chess_player.
|
| Lines stored as conditions on hist pairs.
| ============================================================

@addfunc+
@dyn,var+
@dyn:(chess__book_hit) = 0
@-

| pattern checks always run first
@chess__pattern_check+
@-

| exit early if pattern matched or past book depth
if, (chess__book_hit) = 1
     @print+
          +.-
     @-
if, (chess__book_moves) > 15
     @print+
          +Out of book — minimax takes over.-
     @-

| ============================================================
| WHITE LINES (engine plays white, odd hist indices = opponent)
| ============================================================

| ── RUY LOPEZ (King's Pawn / e5) ────────────────────────────
| 1.e4 e5 2.Nf3 Nc6 3.Bb5 a6 4.Ba4 Nf6 5.O-O Be7 6.Re1 b5 7.Bb3 d6 8.c3

| W move 1: e2-e4
if, (chess__book_moves) = 0,(chess_turn) = w,(chess__book_hit) = 0
     @dyn,var+
     @dyn:(chess__best_from) = e2
     @dyn:(chess__best_to) = e4
     @dyn:(chess__book_hit) = 1
     @-
     @print+
          +Book: Ruy Lopez — e4-
     @-

| W move 2: Nf3 (after opponent played e5)
if, (chess__book_moves) = 2,(chess_turn) = w,(chess__book_hit) = 0
     if, (chess__hist_from_1) = e7,(chess__hist_to_1) = e5
          @dyn,var+
          @dyn:(chess__best_from) = g1
          @dyn:(chess__best_to) = f3
          @dyn:(chess__book_hit) = 1
          @-
          @print+
               +Book: Ruy Lopez — Nf3-
          @-

| W move 3: Bb5 (after Nc6)
if, (chess__book_moves) = 4,(chess_turn) = w,(chess__book_hit) = 0
     if, (chess__hist_from_1) = e7,(chess__hist_to_1) = e5
          if, (chess__hist_from_3) = b8,(chess__hist_to_3) = c6
               @dyn,var+
               @dyn:(chess__best_from) = f1
               @dyn:(chess__best_to) = b5
               @dyn:(chess__book_hit) = 1
               @-
               @print+
                    +Book: Ruy Lopez — Bb5-
               @-

| W move 4: Ba4 (after a6)
if, (chess__book_moves) = 6,(chess_turn) = w,(chess__book_hit) = 0
     if, (chess__hist_from_1) = e7,(chess__hist_to_1) = e5
          if, (chess__hist_from_3) = b8,(chess__hist_to_3) = c6
               if, (chess__hist_from_5) = a7,(chess__hist_to_5) = a6
                    @dyn,var+
                    @dyn:(chess__best_from) = b5
                    @dyn:(chess__best_to) = a4
                    @dyn:(chess__book_hit) = 1
                    @-
                    @print+
                         +Book: Ruy Lopez — Ba4-
                    @-

| W move 5: O-O (after Nf6)
if, (chess__book_moves) = 8,(chess_turn) = w,(chess__book_hit) = 0
     if, (chess__hist_from_1) = e7,(chess__hist_to_1) = e5
          if, (chess__hist_from_3) = b8,(chess__hist_to_3) = c6
               if, (chess__hist_from_5) = a7,(chess__hist_to_5) = a6
                    if, (chess__hist_from_7) = g8,(chess__hist_to_7) = f6
                         @dyn,var+
                         @dyn:(chess__best_from) = e1
                         @dyn:(chess__best_to) = g1
                         @dyn:(chess__book_hit) = 1
                         @-
                         @print+
                              +Book: Ruy Lopez — O-O-
                         @-

| W move 6: Re1 (after Be7)
if, (chess__book_moves) = 10,(chess_turn) = w,(chess__book_hit) = 0
     if, (chess__hist_from_1) = e7,(chess__hist_to_1) = e5
          if, (chess__hist_from_3) = b8,(chess__hist_to_3) = c6
               if, (chess__hist_from_9) = f8,(chess__hist_to_9) = e7
                    @dyn,var+
                    @dyn:(chess__best_from) = f1
                    @dyn:(chess__best_to) = e1
                    @dyn:(chess__book_hit) = 1
                    @-
                    @print+
                         +Book: Ruy Lopez — Re1-
                    @-

| W move 7: Bb3 (after b5)
if, (chess__book_moves) = 12,(chess_turn) = w,(chess__book_hit) = 0
     if, (chess__hist_from_1) = e7,(chess__hist_to_1) = e5
          if, (chess__hist_from_3) = b8,(chess__hist_to_3) = c6
               if, (chess__hist_from_11) = b7,(chess__hist_to_11) = b5
                    @dyn,var+
                    @dyn:(chess__best_from) = a4
                    @dyn:(chess__best_to) = b3
                    @dyn:(chess__book_hit) = 1
                    @-
                    @print+
                         +Book: Ruy Lopez — Bb3-
                    @-

| W move 8: c3 (after d6)
if, (chess__book_moves) = 14,(chess_turn) = w,(chess__book_hit) = 0
     if, (chess__hist_from_1) = e7,(chess__hist_to_1) = e5
          if, (chess__hist_from_3) = b8,(chess__hist_to_3) = c6
               if, (chess__hist_from_13) = d7,(chess__hist_to_13) = d6
                    @dyn,var+
                    @dyn:(chess__best_from) = c2
                    @dyn:(chess__best_to) = c3
                    @dyn:(chess__book_hit) = 1
                    @-
                    @print+
                         +Book: Ruy Lopez — c3-
                    @-

| ── SICILIAN NAJDORF ─────────────────────────────────────────
| 1.e4 c5 2.Nf3 d6 3.d4 cxd4 4.Nxd4 Nf6 5.Nc3 a6 6.Bg5 e6 7.f4 Be7 8.Qf3

| W move 2: Nf3 (after c5)
if, (chess__book_moves) = 2,(chess_turn) = w,(chess__book_hit) = 0
     if, (chess__hist_from_1) = c7,(chess__hist_to_1) = c5
          @dyn,var+
          @dyn:(chess__best_from) = g1
          @dyn:(chess__best_to) = f3
          @dyn:(chess__book_hit) = 1
          @-
          @print+
               +Book: Sicilian — Nf3-
          @-

| W move 3: d4 (after d6)
if, (chess__book_moves) = 4,(chess_turn) = w,(chess__book_hit) = 0
     if, (chess__hist_from_1) = c7,(chess__hist_to_1) = c5
          if, (chess__hist_from_3) = d7,(chess__hist_to_3) = d6
               @dyn,var+
               @dyn:(chess__best_from) = d2
               @dyn:(chess__best_to) = d4
               @dyn:(chess__book_hit) = 1
               @-
               @print+
                    +Book: Sicilian Najdorf — d4-
               @-

| W move 4: Nxd4 (after cxd4)
if, (chess__book_moves) = 6,(chess_turn) = w,(chess__book_hit) = 0
     if, (chess__hist_from_1) = c7,(chess__hist_to_1) = c5
          if, (chess__hist_from_3) = d7,(chess__hist_to_3) = d6
               if, (chess__hist_from_5) = c5,(chess__hist_to_5) = d4
                    @dyn,var+
                    @dyn:(chess__best_from) = f3
                    @dyn:(chess__best_to) = d4
                    @dyn:(chess__book_hit) = 1
                    @-
                    @print+
                         +Book: Sicilian Najdorf — Nxd4-
                    @-

| W move 5: Nc3 (after Nf6)
if, (chess__book_moves) = 8,(chess_turn) = w,(chess__book_hit) = 0
     if, (chess__hist_from_1) = c7,(chess__hist_to_1) = c5
          if, (chess__hist_from_3) = d7,(chess__hist_to_3) = d6
               if, (chess__hist_from_7) = g8,(chess__hist_to_7) = f6
                    @dyn,var+
                    @dyn:(chess__best_from) = b1
                    @dyn:(chess__best_to) = c3
                    @dyn:(chess__book_hit) = 1
                    @-
                    @print+
                         +Book: Sicilian Najdorf — Nc3-
                    @-

| W move 6: Bg5 (after a6)
if, (chess__book_moves) = 10,(chess_turn) = w,(chess__book_hit) = 0
     if, (chess__hist_from_1) = c7,(chess__hist_to_1) = c5
          if, (chess__hist_from_3) = d7,(chess__hist_to_3) = d6
               if, (chess__hist_from_9) = a7,(chess__hist_to_9) = a6
                    @dyn,var+
                    @dyn:(chess__best_from) = c1
                    @dyn:(chess__best_to) = g5
                    @dyn:(chess__book_hit) = 1
                    @-
                    @print+
                         +Book: Sicilian Najdorf — Bg5-
                    @-

| W move 7: f4 (after e6)
if, (chess__book_moves) = 12,(chess_turn) = w,(chess__book_hit) = 0
     if, (chess__hist_from_1) = c7,(chess__hist_to_1) = c5
          if, (chess__hist_from_3) = d7,(chess__hist_to_3) = d6
               if, (chess__hist_from_11) = e7,(chess__hist_to_11) = e6
                    @dyn,var+
                    @dyn:(chess__best_from) = f2
                    @dyn:(chess__best_to) = f4
                    @dyn:(chess__book_hit) = 1
                    @-
                    @print+
                         +Book: Sicilian Najdorf — f4-
                    @-

| W move 8: Qf3 (after Be7)
if, (chess__book_moves) = 14,(chess_turn) = w,(chess__book_hit) = 0
     if, (chess__hist_from_1) = c7,(chess__hist_to_1) = c5
          if, (chess__hist_from_3) = d7,(chess__hist_to_3) = d6
               if, (chess__hist_from_13) = f8,(chess__hist_to_13) = e7
                    @dyn,var+
                    @dyn:(chess__best_from) = d1
                    @dyn:(chess__best_to) = f3
                    @dyn:(chess__book_hit) = 1
                    @-
                    @print+
                         +Book: Sicilian Najdorf — Qf3-
                    @-

| ── SICILIAN DRAGON ──────────────────────────────────────────
| 1.e4 c5 2.Nf3 d6 3.d4 cxd4 4.Nxd4 Nf6 5.Nc3 g6 6.Be3 Bg7 7.f3 O-O 8.Qd2

| W move 6: Be3 (after g6 instead of a6)
if, (chess__book_moves) = 10,(chess_turn) = w,(chess__book_hit) = 0
     if, (chess__hist_from_1) = c7,(chess__hist_to_1) = c5
          if, (chess__hist_from_3) = d7,(chess__hist_to_3) = d6
               if, (chess__hist_from_9) = g7,(chess__hist_to_9) = g6
                    @dyn,var+
                    @dyn:(chess__best_from) = c1
                    @dyn:(chess__best_to) = e3
                    @dyn:(chess__book_hit) = 1
                    @-
                    @print+
                         +Book: Sicilian Dragon — Be3-
                    @-

| W move 7: f3 (after Bg7)
if, (chess__book_moves) = 12,(chess_turn) = w,(chess__book_hit) = 0
     if, (chess__hist_from_1) = c7,(chess__hist_to_1) = c5
          if, (chess__hist_from_3) = d7,(chess__hist_to_3) = d6
               if, (chess__hist_from_11) = f8,(chess__hist_to_11) = g7
                    @dyn,var+
                    @dyn:(chess__best_from) = f2
                    @dyn:(chess__best_to) = f3
                    @dyn:(chess__book_hit) = 1
                    @-
                    @print+
                         +Book: Sicilian Dragon — f3-
                    @-

| W move 8: Qd2 (after O-O)
if, (chess__book_moves) = 14,(chess_turn) = w,(chess__book_hit) = 0
     if, (chess__hist_from_1) = c7,(chess__hist_to_1) = c5
          if, (chess__hist_from_3) = d7,(chess__hist_to_3) = d6
               if, (chess__hist_from_13) = e8,(chess__hist_to_13) = g8
                    @dyn,var+
                    @dyn:(chess__best_from) = d1
                    @dyn:(chess__best_to) = d2
                    @dyn:(chess__book_hit) = 1

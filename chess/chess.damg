     | black pawns: push 2
     if, (chess_a7) = bP,(chess_a6) = 0,(chess_a5) = 0
          @dyn,var+
          @dyn:(chess__cand_from_(chess__cand_count)) = a7
          @dyn:(chess__cand_to_(chess__cand_count)) = a5
          @dyn:(chess__cand_count) = (chess__cand_count)(+)1
